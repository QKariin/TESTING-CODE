*::before,
*::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    min-width: 0;
}

html {
    overflow-x: hidden;
    max-width: 100%;
}

body {
    overflow-x: hidden;
    max-width: 100%;
    width: 100%;
}

:root {
    --gold: #d4a843;
    --gold-hi: #f0c85a;
    --gold-dim: rgba(212, 168, 67, 0.22);
    --gold-glow: rgba(212, 168, 67, 0.10);
    --black: #0a0705;
    --dark: #110e0a;
    --dark2: #1c1610;
    --dark3: #251e16;
    --text: #d4cfc6;
    --muted: #8a8078;
}

html {
    scroll-behavior: smooth;
}

body {
    background: var(--black);
    color: var(--text);
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    line-height: 1.8;
}

/* ── 3D REVEAL ── */
.r3d {
    opacity: 0;
    transform: perspective(1200px) rotateX(14deg) translateY(36px) scale(0.975);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1),
        transform 1s cubic-bezier(0.16, 1, 0.3, 1);
}

.r3d.in {
    opacity: 1;
    transform: perspective(1200px) rotateX(0deg) translateY(0) scale(1);
}

.r3d.d1 {
    transition-delay: .1s;
}

.r3d.d2 {
    transition-delay: .2s;
}

.r3d.d3 {
    transition-delay: .3s;
}

.r3d.d4 {
    transition-delay: .4s;
}

.r3d.d5 {
    transition-delay: .5s;
}

/* ── NAV ── */
nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 5%;
    background: rgba(10, 7, 5, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(212, 168, 67, 0.25);
    transition: padding 0.4s, background 0.4s;
}

nav.scrolled {
    padding: 0.7rem 5%;
    background: rgba(10, 7, 5, 0.98);
}

.nav-brand {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.08rem;
}

.nav-brand-name {
    font-family: 'Cinzel', serif;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    color: var(--gold);
    text-transform: uppercase;
    line-height: 1;
}

.nav-brand-url {
    font-size: 0.48rem;
    letter-spacing: 0.22em;
    color: var(--muted);
}

.nav-links {
    list-style: none;
    display: flex;
    gap: 2rem;
}

.nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.58rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    transition: color 0.25s;
}

.nav-links a:hover {
    color: var(--gold);
}

.nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
}

.nav-toggle span {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--gold);
    transition: all 0.3s;
}

.nav-toggle.open span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
}

.nav-toggle.open span:nth-child(2) {
    opacity: 0;
}

.nav-toggle.open span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
}

.nav-mobile {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10, 7, 5, 0.99);
    z-index: 190;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 2rem;
}

.nav-mobile.open {
    display: flex;
}

.nav-mobile a {
    font-family: 'Cinzel', serif;
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    transition: color 0.2s;
    padding: 1.1rem 0;
    width: 100%;
    text-align: center;
    border-bottom: 1px solid rgba(212, 168, 67, 0.1);
}

.nav-mobile a:first-child {
    border-top: 1px solid rgba(212, 168, 67, 0.1);
}

.nav-mobile a:last-child {
    color: var(--gold);
    letter-spacing: 0.35em;
    margin-top: 1.5rem;
    border: 1px solid rgba(212, 168, 67, 0.35);
    padding: 1rem 2rem;
    width: auto;
}

.nav-mobile a:hover {
    color: var(--gold);
}

/* ── HERO ── */
.hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8rem 6% 5rem;
    position: relative;
    overflow: hidden;
}

.hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
        radial-gradient(ellipse 80% 65% at 50% 45%, rgba(212, 168, 67, 0.18) 0%, transparent 65%),
        radial-gradient(ellipse 40% 30% at 50% 100%, rgba(212, 168, 67, 0.08) 0%, transparent 60%);
}

.hero-grid {
    display: none;
}

.hero-crown {
    display: none;
}

.hero-ornament {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    margin-bottom: 2.2rem;
    width: min(340px, 70vw);
}

.hero-ornament-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 168, 67, 0.6), transparent);
}

.hero-ornament-dot {
    width: 4px;
    height: 4px;
    background: var(--gold);
    transform: rotate(45deg);
    flex-shrink: 0;
    box-shadow: 0 0 8px rgba(212, 168, 67, 0.6);
}

.hero-eyebrow {
    font-size: 0.55rem;
    letter-spacing: 0.85em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.6rem;
    font-family: 'Cinzel', serif;
    opacity: 0.7;
}

.hero-name {
    font-family: 'Cinzel', serif;
    font-size: clamp(2.4rem, 7vw, 6.5rem);
    font-weight: 400;
    letter-spacing: 0.4em;
    line-height: 1;
    color: #fff;
    text-transform: uppercase;
    text-shadow: 0 0 60px rgba(212, 168, 67, 0.22);
    white-space: nowrap;
}

.hero-name em {
    display: inline;
    color: inherit;
    font-style: normal;
    font-family: inherit;
    font-weight: inherit;
    font-size: inherit;
}

.hero-rule {
    width: 1px;
    height: 80px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    margin: 2.2rem auto;
}

.hero-sub {
    font-family: 'Cinzel', serif;
    font-style: normal;
    font-weight: 400;
    font-size: 0.6rem;
    color: var(--muted);
    letter-spacing: 0.45em;
    text-transform: uppercase;
    margin-bottom: 2.8rem;
}

.hero-btns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
}

.btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.95rem 2.6rem;
    font-family: 'Cinzel', serif;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid var(--gold);
    color: var(--gold);
    background: transparent;
    cursor: pointer;
    transition: color 0.3s;
    position: relative;
    overflow: hidden;
}

.btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.38s ease;
    z-index: 0;
}

.btn>* {
    position: relative;
    z-index: 1;
}

.btn:hover {
    color: var(--black);
}

.btn:hover::before {
    transform: scaleX(1);
}

.btn-ghost {
    border-color: rgba(201, 168, 76, 0.28);
    color: var(--muted);
}

.hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    color: var(--muted);
    font-size: 0.5rem;
    letter-spacing: 0.38em;
    text-transform: uppercase;
}

.hero-scroll-line {
    width: 1px;
    height: 46px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: pulse 2.2s ease-in-out infinite;
}

@keyframes pulse {

    0%,
    100% {
        opacity: .8;
    }

    50% {
        opacity: .1;
    }
}

/* ── DISCLAIMER ── */
.disclaimer {
    padding: 1.3rem 5%;
    background: linear-gradient(90deg, transparent, rgba(212, 168, 67, 0.10), transparent);
    border-top: 1px solid rgba(212, 168, 67, 0.35);
    border-bottom: 1px solid rgba(212, 168, 67, 0.35);
}

.disclaimer-inner {
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.1rem;
    flex-wrap: wrap;
}

.disclaimer svg {
    width: 16px;
    height: 16px;
    color: var(--gold);
    flex-shrink: 0;
}

.disclaimer p {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--text);
    text-align: center;
}

.disclaimer strong {
    color: var(--gold);
    font-weight: 500;
}

/* ── SHARED ── */
section {
    padding: 9rem 5%;
    scroll-margin-top: 70px;
}

.eyebrow {
    display: block;
    font-family: 'Cinzel', serif;
    font-size: 0.58rem;
    letter-spacing: 0.65em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.1rem;
    text-align: center;
    opacity: 0.9;
}

.s-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(2.2rem, 5.5vw, 4.2rem);
    font-weight: 400;
    text-align: center;
    color: #fff;
    line-height: 1.15;
    margin-bottom: 1.2rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.s-title em {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    color: var(--gold);
    font-size: 1.15em;
    text-transform: none;
    letter-spacing: 0.02em;
}

.s-intro {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 5rem;
    color: var(--muted);
    font-size: 0.84rem;
    line-height: 2.15;
}

.vline {
    width: 1px;
    height: 52px;
    background: linear-gradient(to bottom, transparent, var(--gold), transparent);
    margin: 0 auto 2.2rem;
}

/* ── ABOUT ── */
.about {
    background: var(--dark2);
    position: relative;
}

.about::before {
    content: '';
    display: block;
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 168, 67, 0.40), transparent);
}

.about-inner {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
}

.about-quote {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.7rem, 3.8vw, 2.6rem);
    color: #fff;
    line-height: 1.5;
    margin-bottom: 2.2rem;
    text-shadow: 0 2px 40px rgba(212, 168, 67, 0.08);
}

.about-body {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(1rem, 1.9vw, 1.3rem);
    color: var(--text);
    line-height: 2.3;
    margin-bottom: 1.4rem;
}

/* ── ONLINE TEASER ── */
.online-teaser {
    background: var(--black);
    position: relative;
    overflow: hidden;
}

.online-teaser::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
        linear-gradient(180deg, #0a0705 0%, #130f08 50%, #0a0705 100%),
        radial-gradient(ellipse 70% 60% at 50% 50%, rgba(212, 168, 67, 0.12) 0%, transparent 70%);
    pointer-events: none;
}

.online-teaser-inner {
    position: relative;
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
}

.online-teaser-body {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(1.1rem, 2.2vw, 1.5rem);
    color: var(--text);
    line-height: 2.2;
    margin-bottom: 2.5rem;
}

.online-teaser-body strong {
    color: var(--gold);
    font-style: normal;
    font-weight: 400;
}

/* ── SESSION ACCORDION ── */
.sessions {
    background: var(--dark2);
    position: relative;
}

.sessions::before {
    content: '';
    display: block;
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 168, 67, 0.40), transparent);
}

.sessions-list {
    max-width: 860px;
    margin: 0 auto;
    border-top: 1px solid var(--gold-dim);
}

.sess-item {
    border-bottom: 1px solid var(--gold-dim);
}

.sess-trigger {
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.8rem 0.5rem;
    text-align: left;
    transition: background 0.25s, transform 0.25s;
    transform-origin: left center;
}

.sess-trigger:hover {
    background: rgba(201, 168, 76, 0.025);
    transform: perspective(600px) translateZ(3px);
}

.sess-left {
    display: flex;
    align-items: center;
    gap: 1.4rem;
}

.sess-icon {
    width: 24px;
    height: 24px;
    color: var(--gold);
    opacity: 0.75;
    flex-shrink: 0;
    transition: opacity 0.2s, transform 0.3s;
}

.sess-trigger:hover .sess-icon,
.sess-item.open .sess-icon {
    opacity: 1;
    transform: scale(1.1);
}

.sess-name {
    font-family: 'Cinzel', serif;
    font-size: clamp(0.9rem, 2.5vw, 1.2rem);
    font-weight: 400;
    color: #fff;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s;
}

.sess-item.open .sess-name {
    color: var(--gold);
}

.sess-chevron {
    width: 16px;
    height: 16px;
    color: var(--gold);
    opacity: 0.4;
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s;
}

.sess-item.open .sess-chevron {
    transform: rotate(180deg);
    opacity: 1;
}

.sess-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.sess-body-inner {
    padding: 0 0.5rem 2.2rem calc(24px + 1.4rem + 0.5rem);
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 2.1;
    max-width: 560px;
}

/* ── RATES ── */
.rates {
    background: var(--black);
    border-top: 1px solid rgba(212, 168, 67, 0.18);
}

.rates-wrap {
    max-width: 760px;
    margin: 0 auto;
}

.rates-label {
    font-family: 'Cinzel', serif;
    font-size: 0.52rem;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
    margin-bottom: 0.8rem;
}

.rates-table {
    width: 100%;
    border-collapse: collapse;
}

.rates-table tr {
    border-bottom: 1px solid var(--gold-dim);
    transition: background 0.2s, transform 0.2s;
}

.rates-table tbody tr:hover {
    background: rgba(201, 168, 76, 0.04);
    transform: perspective(800px) translateZ(2px);
}

.rates-table th {
    font-family: 'Cinzel', serif;
    font-size: 0.5rem;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--gold);
    padding: 0.9rem 1rem;
    text-align: left;
    font-weight: 400;
    border-bottom: 1px solid rgba(201, 168, 76, 0.28);
}

.rates-table th:last-child {
    text-align: right;
}

.rates-table td {
    padding: 1.3rem 1rem;
    font-size: 0.85rem;
    color: var(--text);
    vertical-align: middle;
}

.rates-table td.r-time {
    font-family: 'Cinzel', serif;
    font-size: 0.9rem;
    color: var(--muted);
    white-space: nowrap;
    letter-spacing: 0.06em;
}

.rates-table td.r-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 300;
    color: var(--gold);
    text-align: right;
    white-space: nowrap;
    text-shadow: 0 0 40px rgba(212, 168, 67, 0.45);
}

.rates-table td.r-price sup {
    font-size: 0.85rem;
    vertical-align: super;
}

.deposit-box {
    margin-top: 2rem;
    border: 1px solid rgba(212, 168, 67, 0.35);
    background: linear-gradient(135deg, rgba(212, 168, 67, 0.09), transparent);
    padding: 1.8rem 2rem;
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
    transition: border-color 0.3s;
}

.deposit-box:hover {
    border-color: rgba(212, 168, 67, 0.55);
}

.deposit-box svg {
    width: 16px;
    height: 16px;
    color: var(--gold);
    flex-shrink: 0;
    margin-top: 0.2rem;
}

.deposit-box p {
    font-size: 0.79rem;
    color: var(--text);
    line-height: 1.95;
}

.deposit-box strong {
    color: var(--gold);
    font-weight: 400;
}

.online-rates-note {
    margin-top: 1px;
    padding: 1.4rem 2rem;
    background: var(--dark2);
    border: 1px solid var(--gold-dim);
    font-size: 0.77rem;
    color: var(--muted);
    line-height: 1.9;
    text-align: center;
}

.online-rates-note strong {
    color: var(--gold);
    font-weight: 400;
}

/* ── PROCESS ── */
.process {
    background: var(--dark2);
    position: relative;
}

.process::before {
    content: '';
    display: block;
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 168, 67, 0.40), transparent);
}

.steps {
    max-width: 880px;
    margin: 0 auto;
}

.step {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 0 2rem;
    padding: 2.8rem 0;
    border-bottom: 1px solid var(--gold-dim);
    align-items: start;
    transition: transform 0.3s;
}

.step:last-child {
    border-bottom: none;
}

.step:hover {
    transform: perspective(800px) translateZ(4px);
}

.step-num {
    font-family: 'Cinzel', serif;
    font-size: 3rem;
    font-weight: 400;
    color: rgba(212, 168, 67, 0.28);
    line-height: 1;
    text-align: right;
    padding-right: 2rem;
    border-right: 1px solid var(--gold-dim);
    letter-spacing: 0.02em;
}

.step-content {
    padding-left: 0.5rem;
}

.step-content svg {
    width: 20px;
    height: 20px;
    color: var(--gold);
    opacity: 0.65;
    margin-bottom: 0.9rem;
    display: block;
}

.step-content h3 {
    font-family: 'Cinzel', serif;
    font-size: clamp(0.85rem, 2vw, 1.1rem);
    font-weight: 500;
    color: #fff;
    margin-bottom: 0.5rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
}

.step-content p {
    font-size: 0.79rem;
    color: var(--muted);
    line-height: 1.98;
}

.step-content strong {
    color: var(--text);
    font-weight: 300;
}

/* ── RULES ── */
.rules {
    background: var(--black);
    border-top: 1px solid rgba(212, 168, 67, 0.18);
}

.rules-inner {
    max-width: 720px;
    margin: 0 auto;
    counter-reset: rc;
}

.rule {
    counter-increment: rc;
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1.5rem;
    padding: 1.7rem 0;
    border-bottom: 1px solid rgba(201, 168, 76, 0.07);
    align-items: start;
}

.rule::before {
    content: counter(rc, decimal-leading-zero);
    font-family: 'Cinzel', serif;
    font-size: 1.2rem;
    color: rgba(212, 168, 67, 0.45);
    line-height: 1.5;
    text-align: right;
}

.rule p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.98;
}

.rule.hl {
    background: rgba(212, 168, 67, 0.09);
    border-left: 3px solid var(--gold);
    padding-left: 1.2rem;
    margin-left: -1.2rem;
}

.rule.hl p {
    color: #fff;
}

.rule strong {
    color: var(--gold);
